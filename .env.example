# ─────────────────────────────────────────────────────────
# TOUSLESMATCHS — Variables d'environnement
# Copie ce fichier en .env et remplis les valeurs réelles
# ─────────────────────────────────────────────────────────

# Telegram Bot Token (obligatoire pour le bot)
TELEGRAM_BOT_TOKEN=

# Groq API Key (obligatoire pour l'analyse IA)
# Obtenir gratuitement sur https://console.groq.com
GROQ_API_KEY=

# Football Data API Key (obligatoire pour les données de matchs)
# Obtenir gratuitement sur https://www.football-data.org/client/register
FOOTBALL_DATA_KEY=
