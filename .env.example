# ============================================================
# HERMES COUNCIL - Variables d'environnement
# Copie ce fichier en .env et remplis tes clés API
# ============================================================

# --- CHEF : Claude Anthropic ---
# Obtenir sur : https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-XXXXXX

# --- Agent 1 : GPT-4o Mini (OpenAI) ---
# Obtenir sur : https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-XXXXXX

# --- Agent 2 : Gemini Flash (Google) ---
# Obtenir sur : https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIzaSyXXXXXX

# --- Agent 3 : Mistral ---
# Obtenir sur : https://console.mistral.ai/api-keys
MISTRAL_API_KEY=XXXXXX

# --- Agent 4 : Groq (Llama 3) ---
# Obtenir sur : https://console.groq.com/keys
GROQ_API_KEY=gsk_XXXXXX

# --- API Sportive (ton abonnement) ---
# API-Football (RapidAPI) - adapter selon ton fournisseur
SPORTS_API_KEY=XXXXXX
SPORTS_API_HOST=v3.football.api-sports.io
# Options: api-football, thesportsdb, sportmonks, odds-api
SPORTS_API_PROVIDER=api-football

# --- Site ---
# Chemin vers le fichier HTML à régénérer
SITE_HTML_PATH=/app/site/index.html
SITE_TEMPLATE_PATH=/app/site/template.html

# --- Liens Bookmakers (affiliation) ---
WINAMAX_LINK=https://www.winamax.fr/parrain?code=WMX8M5
BETCLIC_LINK=https://www.betclic.fr/affiliation-TONLIEN
UNIBET_LINK=https://www.unibet.fr/affiliation-TONLIEN
PMU_LINK=https://www.pmu.fr/affiliation-TONLIEN
ZEBET_LINK=https://www.zebet.fr/affiliation-TONLIEN
PARIONSSPORT_LINK=https://www.parionssport.fdj.fr/affiliation-TONLIEN
NETBET_LINK=https://www.netbet.fr/affiliation-TONLIEN
TIKTOK_LINK=https://www.tiktok.com/@touslesmatchs.com

# --- Telegram ---
# Créer un bot : parle à @BotFather sur Telegram → /newbot
TELEGRAM_BOT_TOKEN=1234567890:ABCxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ID du canal gratuit (ex: @touslesmatchs ou -1001234567890)
TELEGRAM_FREE_CHANNEL_ID=@toncanalgratuit
# ID du canal premium privé (récupère l'ID via @userinfobot)
TELEGRAM_PREMIUM_CHANNEL_ID=-1009876543210

# --- Timezone ---
TZ=Europe/Paris
