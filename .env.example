# CONFIGURATION — À COPIER EN .env SUR LE VPS
# ═══════════════════════════════════════════════════════

# FOOTBALL DATA
RAPIDAPI_KEY=
FOOTBALL_DATA_KEY=

# IAs — MULTI-IA FALLBACK (Phase 2)
GROQ_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=

# STRIPE (Phase 5)
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=

# TELEGRAM
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_PREMIUM_CHAT_ID=

# ═══════════════════════════════════════════════════════
# INSTRUCTIONS:
# ═══════════════════════════════════════════════════════
# 1. Copier ce fichier en .env sur le VPS
# 2. Remplir les clés de chaque service
# 3. Pour Phase 2 (multi-IA):
#    - DEEPSEEK_API_KEY: obligatoire (chef par défaut)
#    - OPENROUTER_API_KEY: optionnel (fallback 1)
#    - GEMINI_API_KEY: optionnel (fallback 2)
#    - MISTRAL_API_KEY: optionnel (fallback 3)
# 4. Tester: node scripts/verify_apis.js
