www.touslesmatchs.com {
    # Stripe webhook
    handle /stripe/webhook {
        reverse_proxy stripe-webhook:4242
    }

    # API backend
    handle /api/* {
        uri strip_prefix /api
        reverse_proxy api:3001
    }

    # Frontend React (SPA)
    root * /srv
    file_server
    try_files {path} /index.html
    encode gzip
}

touslesmatchs.com {
    redir https://www.touslesmatchs.com{uri} permanent
}
