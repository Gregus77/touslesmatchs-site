www.touslesmatchs.com {
    # API proxy vers le backend
    handle /api/* {
        uri strip_prefix /api
        reverse_proxy api:3001
    }

    # Frontend React
    root * /srv
    file_server
    try_files {path} /index.html
    encode gzip
}

touslesmatchs.com {
    redir https://www.touslesmatchs.com{uri} permanent
}
